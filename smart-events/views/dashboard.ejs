<%- include('partials/header') %>

<div class="container mt-4">
  <h2 class="fw-bold mb-1">My Dashboard</h2>
  <p class="text-muted mb-4">Welcome back, <%= user.name %>!</p>

  <% if (success) { %>
    <div class="alert alert-success"><%= success %></div>
  <% } %>
  <% if (error) { %>
    <div class="alert alert-danger"><%= error %></div>
  <% } %>

  <div class="card border-0 shadow-sm">
    <div class="card-header bg-white">
      <h5 class="mb-0 fw-bold">
        <i class="bi bi-ticket-perforated"></i> My Bookings
      </h5>
    </div>
    <div class="card-body p-0">
      <% if (bookings.length === 0) { %>
        <div class="text-center py-5">
          <i class="bi bi-calendar-x" style="font-size:3rem; color:#aaa;"></i>
          <h5 class="mt-3 text-muted">No bookings yet</h5>
          <p class="text-muted">Browse events and book your first ticket!</p>
          <a href="/" class="btn btn-primary">Browse Events</a>
        </div>
      <% } else { %>
        <table class="table table-hover mb-0">
          <thead class="table-primary">
            <tr>
              <th>Event</th>
              <th>Date</th>
              <th>Location</th>
              <th>Tickets</th>
              <th>Booked On</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% bookings.forEach(booking => { %>
              <tr>
                <td class="fw-semibold">
                  <% if (booking.event) { %>
                    <%= booking.event.title %>
                  <% } else { %>
                    Event no longer available
                  <% } %>
                </td>
                <td>
                  <% if (booking.event) { %>
                    <%= new Date(booking.event.date).toLocaleDateString('en-ZA') %>
                  <% } else { %>
                    —
                  <% } %>
                </td>
                <td>
                  <% if (booking.event) { %>
                    <%= booking.event.location %>
                  <% } else { %>
                    —
                  <% } %>
                </td>
                <td><%= booking.numberOfTickets %></td>
                <td><%= new Date(booking.createdAt).toLocaleDateString('en-ZA') %></td>
                <td>
                  <% if (booking.status === 'confirmed') { %>
                    <span class="badge bg-success">Confirmed</span>
                    <form action="/bookings/<%= booking._id %>/cancel" method="POST" class="d-inline ms-2"
                          onsubmit="return confirm('Are you sure you want to cancel this booking?')">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <button type="submit" class="btn btn-sm btn-outline-danger">Cancel</button>
                    </form>
                  <% } else { %>
                    <span class="badge bg-danger">Cancelled</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>
  </div>
</div>

<%- include('partials/footer') %>