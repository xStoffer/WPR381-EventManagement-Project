<%- include('partials/header') %>

<div class="container mt-4">
  <a href="/" class="btn btn-outline-secondary mb-4">
    <i class="bi bi-arrow-left"></i> Back to Events
  </a>

  <% if (error) { %>
    <div class="alert alert-danger"><%= error %></div>
  <% } %>
  <% if (success) { %>
    <div class="alert alert-success"><%= success %></div>
  <% } %>

  <div class="row">
    <!-- Event Details -->
    <div class="col-md-8">
      <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4">
          <span class="badge bg-primary mb-2"><%= event.category %></span>
          <h2 class="fw-bold"><%= event.title %></h2>
          <p class="text-muted">
            <i class="bi bi-calendar3"></i>
            <%= new Date(event.date).toLocaleDateString('en-ZA', { dateStyle: 'long' }) %>
            &nbsp;|&nbsp;
            <i class="bi bi-geo-alt"></i> <%= event.location %>
          </p>
          <hr>
          <p><%= event.description %></p>
        </div>
      </div>
    </div>

    <!-- Booking Panel -->
    <div class="col-md-4">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-primary text-white">
          <h5 class="mb-0">Book Tickets</h5>
        </div>
        <div class="card-body">
          <p>
            <strong>Capacity:</strong> <%= event.capacity %>
          </p>
          <p>
            <strong>Available:</strong>
            <% if (event.ticketsAvailable > 0) { %>
              <span class="text-success"><%= event.ticketsAvailable %></span>
            <% } else { %>
              <span class="text-danger">Sold Out</span>
            <% } %>
          </p>

          <% if (event.ticketsAvailable > 0) { %>
            <% if (user) { %>
              <form action="/events/<%= event._id %>/book" method="POST">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <div class="mb-3">
                  <label class="form-label">Number of Tickets</label>
                  <input
                    type="number"
                    name="numberOfTickets"
                    class="form-control"
                    min="1"
                    max="<%= event.ticketsAvailable %>"
                    value="1"
                    required
                  >
                </div>
                <button type="submit" class="btn btn-primary w-100">
                  Confirm Booking
                </button>
              </form>
            <% } else { %>
              <div class="alert alert-info">
                <a href="/auth/login">Login</a> to book tickets for this event.
              </div>
            <% } %>
          <% } else { %>
            <div class="alert alert-danger">
              This event is sold out.
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>