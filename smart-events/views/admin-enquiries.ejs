<%- include('partials/header') %>

<div class="container">
  <div class="table-container">
    <h2>Customer Enquiries</h2>
    <table class="table table-bordered table-hover">
      <thead class="table-primary">
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Subject</th>
          <th>Message</th>
          <th>Date</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% enquiries.forEach(enquiry => { %>
          <tr>
            <td><%= enquiry.name %></td>
            <td><%= enquiry.email %></td>
            <td><%= enquiry.subject %></td>
            <td><%= enquiry.message %></td>
            <td><%= new Date(enquiry.createdAt).toLocaleDateString('en-ZA') %></td>
            <td><span class="badge <%= enquiry.status === 'unread' ? 'bg-warning' : 'bg-success' %>"><%= enquiry.status %></span></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('partials/footer') %>